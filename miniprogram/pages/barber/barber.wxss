.wrap { padding: 24rpx 24rpx 180rpx; display: flex; flex-direction: column; gap: 20rpx; }
/* 深色影棚风头部，铺到屏幕两侧与顶部 */
.header { display: flex; gap: 28rpx; align-items: center; margin: -24rpx -24rpx 0; padding: 56rpx 40rpx; background: linear-gradient(160deg, #243a2c, #14201a); }
.avatar { width: 150rpx; height: 150rpx; border-radius: 50%; border: 3rpx solid #c9a96a; }
.h-info { flex: 1; }
.name-row { display: flex; align-items: center; justify-content: space-between; }
.name { font-size: 38rpx; font-weight: 700; color: #f3ead6; }
.h-title { font-size: 26rpx; color: #c9a96a; margin-top: 6rpx; letter-spacing: 2rpx; }
.h-rate { font-size: 24rpx; color: #d3dcd6; margin-top: 8rpx; }
.follow-btn { font-size: 24rpx; color: #c9a96a; border: 1rpx solid #c9a96a; border-radius: 999rpx; padding: 6rpx 24rpx; }
.follow-active { background: #c9a96a; color: #1f3026; font-weight: 600; }
.spec-row { margin-top: 14rpx; display: flex; flex-wrap: wrap; align-items: center; gap: 10rpx; }
.spec-label { font-size: 24rpx; color: #9aa79f; }
.spec-chip { font-size: 22rpx; color: #e3d4b0; border: 1rpx solid rgba(201,169,106,0.6); border-radius: 6rpx; padding: 2rpx 12rpx; }
.block { padding: 24rpx; }
.block-title { font-weight: 600; color: #1f3026; margin-bottom: 16rpx; }
.svc-row { display: flex; justify-content: space-between; align-items: center; padding: 22rpx 16rpx; border-radius: 12rpx; border: 1rpx solid #eee; margin-bottom: 12rpx; }
.svc-active { border-color: #c9a96a; background: #faf6ee; }
.svc-text { display: flex; flex-direction: column; gap: 6rpx; flex: 1; margin-right: 16rpx; }
.svc-name { color: #1f3026; }
.svc-desc { font-size: 22rpx; color: #8a958e; }
.price { color: #c9a96a; font-weight: 600; }
.date-tabs { white-space: nowrap; margin-bottom: 16rpx; }
.date-tab { display: inline-block; text-align: center; padding: 12rpx 24rpx; margin-right: 12rpx; border-radius: 12rpx; background: #f1f2f0; font-size: 26rpx; }
.date-active { background: #1f3026; color: #fff; }
.date-tab .md { font-size: 22rpx; }
.slot-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.slot { width: calc(25% - 12rpx); text-align: center; padding: 18rpx 0; border-radius: 10rpx; background: #f1f2f0; font-size: 26rpx; }
.slot-active { background: #c9a96a; color: #1f3026; font-weight: 600; }
.slot-disabled { color: #ccc; background: #f7f7f7; }
.footer { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; padding: 20rpx 24rpx; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.06); }
.sel-info { font-size: 24rpx; color: #8a958e; margin-bottom: 10rpx; }
